PORT=3000
HOST=0.0.0.0
PUBLIC_BASE_URL=http://localhost:3000
# USER_AGENT defaults to MCP-Legal-Chile/<package.json version> if unset.
# USER_AGENT=MCP-Legal-Chile/1.13.0 (https://mcp-legal-chile.onrender.com)
# WEB_SEARCH_USER_AGENT overrides both the browser-like and bot-style UAs used for scraping.
# LOG_LEVEL=info        # debug | info | warn | error
# LOG_FORMAT=json        # json (structured, auto-on when RENDER is set) | text (default locally)
# CACHE_MAX_ENTRIES=2000 # LRU cap per in-memory cache tier
# CONTACT_EMAIL=you@example.com   # polite pool OpenAlex/Crossref (mailto=)
FETCH_TIMEOUT_MS=12000
TC_TIMEOUT_MS=18000
SEARCH_TOOL_TIMEOUT_MS=22000
JURIS_WEB_BUDGET_MS=6500
WEB_SEARCH_TIMEOUT_MS=5000
SPARQL_TIMEOUT_MS=10000
PACK_TOTAL_MS=18000
PACK_TIMEOUT_MS=11000
WARMUP_ON_BOOT=1
# RATE_LIMIT_PER_MINUTE=60
# HTTP_REQUEST_TIMEOUT_MS=60000
# HTTP_HEADERS_TIMEOUT_MS=65000
# HTTP_KEEPALIVE_TIMEOUT_MS=61000
# Optional self-host only (not required; open access by default):
# REDIS_URL=redis://...
# MCP_API_KEYS=demo:replace-me:200
# LEYCHILE_MIN_INTERVAL_MS=1000
# LEYCHILE_429_CACHE_MS=60000
# MAX_RETRY_AFTER_MS=30000
# CIRCUIT_OPEN_MS=90000
# CIRCUIT_THRESHOLD=3
# UNIFIED_BUDGET_MS=8000
